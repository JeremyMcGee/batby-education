@page "/students/edit/{Id:guid}"
@rendermode InteractiveServer
@using BatbyEducation.Application.Commands.Students
@using BatbyEducation.Domain.Common
@using BatbyEducation.Domain.Entities
@using BatbyEducation.Domain.Interfaces
@using MediatR
@inject IMediator Mediator
@inject IStudentRepository StudentRepository
@inject ITutorRepository TutorRepository
@inject ITutorAvailabilityRepository AvailabilityRepository
@inject IAuditEntryRepository AuditEntryRepository
@inject NavigationManager Navigation

<PageTitle>Edit Student</PageTitle>

<h3>Edit Student</h3>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_notFound)
{
    <div class="alert alert-warning">Student not found.</div>
    <a href="/students" class="btn btn-secondary">Back to Students</a>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="EditStudent">
                <div class="mb-3">
                    <label for="name" class="form-label">Name *</label>
                    <InputText id="name" class="form-control" @bind-Value="_model.Name" />
                    @if (GetError("Name") is { } nameErr)
                    {
                        <div class="text-danger small mt-1">@nameErr</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email *</label>
                    <InputText id="email" class="form-control" @bind-Value="_model.Email" />
                    @if (GetError("Email") is { } emailErr)
                    {
                        <div class="text-danger small mt-1">@emailErr</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="phone" class="form-label">Phone Number *</label>
                    <InputText id="phone" class="form-control" @bind-Value="_model.PhoneNumber" />
                    @if (GetError("PhoneNumber") is { } phoneErr)
                    {
                        <div class="text-danger small mt-1">@phoneErr</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="guardianName" class="form-label">Guardian Name *</label>
                    <InputText id="guardianName" class="form-control" @bind-Value="_model.GuardianName" />
                    @if (GetError("GuardianName") is { } guardianNameErr)
                    {
                        <div class="text-danger small mt-1">@guardianNameErr</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="guardianEmail" class="form-label">Guardian Email *</label>
                    <InputText id="guardianEmail" class="form-control" @bind-Value="_model.GuardianEmail" />
                    @if (GetError("GuardianEmail") is { } guardianEmailErr)
                    {
                        <div class="text-danger small mt-1">@guardianEmailErr</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="hourlyRate" class="form-label">Hourly Rate (£) <small class="text-muted">(optional)</small></label>
                    <InputNumber id="hourlyRate" class="form-control" @bind-Value="_model.HourlyRate" />
                    <div class="form-text">Leave blank to use tutor's default rate. Valid range: £0.01–£999.99</div>
                    @if (GetError("HourlyRate") is { } rateErr)
                    {
                        <div class="text-danger small mt-1">@rateErr</div>
                    }
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" @bind="_model.IsActive" />
                        <label class="form-check-label" for="isActive">Active</label>
                    </div>
                    <div class="form-text">Inactive students will not appear in booking or invoice dropdowns.</div>
                </div>

                <hr class="my-4" />
                <h5>Default Booking Preferences <small class="text-muted">(optional)</small></h5>
                <p class="text-muted small">These will be pre-filled when booking a session for this student.</p>

                <div class="mb-3">
                    <label for="defaultTutor" class="form-label">Default Tutor</label>
                    <select id="defaultTutor" class="form-select" @bind="_model.DefaultTutorId" @bind:after="OnDefaultTutorChanged">
                        <option value="">-- None --</option>
                        @foreach (var tutor in _tutors)
                        {
                            <option value="@tutor.Id">@tutor.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="defaultSubject" class="form-label">Default Subject</label>
                    <select id="defaultSubject" class="form-select" @bind="_model.DefaultSubject">
                        <option value="">-- None --</option>
                        @foreach (var subject in _availableSubjects)
                        {
                            <option value="@subject">@subject</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="defaultDay" class="form-label">Default Day</label>
                    <select id="defaultDay" class="form-select" @bind="_model.DefaultDay" @bind:after="OnDefaultDayChanged">
                        <option value="">-- None --</option>
                        <option value="@DayOfWeek.Monday">Monday</option>
                        <option value="@DayOfWeek.Tuesday">Tuesday</option>
                        <option value="@DayOfWeek.Wednesday">Wednesday</option>
                        <option value="@DayOfWeek.Thursday">Thursday</option>
                        <option value="@DayOfWeek.Friday">Friday</option>
                        <option value="@DayOfWeek.Saturday">Saturday</option>
                        <option value="@DayOfWeek.Sunday">Sunday</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Default Slot</label>
                    @if (_defaultSlots.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var slot in _defaultSlots)
                            {
                                var isSelected = _model.DefaultStartTime == slot.Start;
                                <button type="button"
                                        class="btn btn-sm @(isSelected ? "btn-success" : "btn-outline-success")"
                                        @onclick="() => SelectDefaultSlot(slot)">
                                    @slot.Start.ToString("HH:mm")–@slot.End.ToString("HH:mm")
                                </button>
                            }
                        </div>
                    }
                    else if (_model.DefaultTutorId.HasValue && _model.DefaultDay.HasValue)
                    {
                        <div class="text-muted">No slots configured for this tutor on this day.</div>
                    }
                    else
                    {
                        <div class="text-muted">Select a tutor and day to see available slots.</div>
                    }
                </div>

                @if (_generalError is not null)
                {
                    <div class="alert alert-danger">@_generalError</div>
                }

                @if (_successMessage is not null)
                {
                    <div class="alert alert-success">@_successMessage</div>
                }

                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @(_submitting ? "Saving..." : "Save Changes")
                </button>
                <a href="/students" class="btn btn-secondary ms-2">Cancel</a>
            </EditForm>
        </div>
    </div>

    @if (_auditEntries is not null && _auditEntries.Count > 0)
    {
        <div class="mt-4">
            <h5>Change History</h5>
            <table class="table table-sm table-bordered">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Field</th>
                        <th>Old Value</th>
                        <th>New Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _auditEntries.OrderByDescending(e => e.ChangedAt))
                    {
                        <tr>
                            <td>@entry.ChangedAt.ToString("g")</td>
                            <td>@entry.FieldName</td>
                            <td>@entry.OldValue</td>
                            <td>@entry.NewValue</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private StudentFormModel _model = new();
    private List<ValidationError> _errors = new();
    private string? _generalError;
    private string? _successMessage;
    private bool _submitting;
    private bool _loading = true;
    private bool _notFound;
    private IReadOnlyList<AuditEntry>? _auditEntries;
    private List<Tutor> _tutors = new();
    private List<string> _availableSubjects = new();
    private List<(TimeOnly Start, TimeOnly End)> _defaultSlots = new();

    protected override async Task OnInitializedAsync()
    {
        _tutors = (await TutorRepository.GetAllAsync()).ToList();

        var student = await StudentRepository.GetByIdAsync(Id);
        if (student is null)
        {
            _notFound = true;
        }
        else
        {
            _model = new StudentFormModel
            {
                Name = student.Name,
                Email = student.Email.Value,
                PhoneNumber = student.PhoneNumber,
                GuardianName = student.GuardianName,
                GuardianEmail = student.GuardianEmail.Value,
                HourlyRate = student.HourlyRate,
                IsActive = student.IsActive,
                DefaultTutorId = student.DefaultTutorId,
                DefaultSubject = student.DefaultSubject,
                DefaultDay = student.DefaultDay,
                DefaultStartTime = student.DefaultStartTime
            };

            // Populate subjects for the selected default tutor
            if (_model.DefaultTutorId.HasValue)
            {
                var selectedTutor = _tutors.FirstOrDefault(t => t.Id == _model.DefaultTutorId);
                _availableSubjects = selectedTutor?.Subjects.ToList() ?? new List<string>();
            }

            // Load default slots if tutor and day are set
            await LoadDefaultSlots();

            _auditEntries = await AuditEntryRepository.GetByEntityIdAsync(Id);
        }
        _loading = false;
    }

    private async Task OnDefaultTutorChanged()
    {
        var selectedTutor = _tutors.FirstOrDefault(t => t.Id == _model.DefaultTutorId);
        _availableSubjects = selectedTutor?.Subjects.ToList() ?? new List<string>();
        if (_availableSubjects.Count > 0 && !_availableSubjects.Contains(_model.DefaultSubject ?? ""))
        {
            _model.DefaultSubject = null;
        }
        await LoadDefaultSlots();
    }

    private async Task OnDefaultDayChanged()
    {
        await LoadDefaultSlots();
    }

    private async Task LoadDefaultSlots()
    {
        _defaultSlots.Clear();

        if (!_model.DefaultTutorId.HasValue || !_model.DefaultDay.HasValue)
            return;

        var slots = await AvailabilityRepository.GetByTutorAndDayAsync(_model.DefaultTutorId.Value, _model.DefaultDay.Value);
        _defaultSlots = slots
            .Where(s => s.IsAvailable)
            .OrderBy(s => s.StartTime)
            .Select(s => (s.StartTime, s.EndTime))
            .ToList();
    }

    private void SelectDefaultSlot((TimeOnly Start, TimeOnly End) slot)
    {
        _model.DefaultStartTime = slot.Start;
    }

    private string? GetError(string field) =>
        _errors.FirstOrDefault(e => e.Field == field)?.Message;

    private async Task HandleSubmit()
    {
        _errors.Clear();
        _generalError = null;
        _successMessage = null;
        _submitting = true;

        try
        {
            var command = new UpdateStudentCommand(
                Id,
                _model.Name,
                _model.Email,
                _model.PhoneNumber,
                _model.GuardianName,
                _model.GuardianEmail,
                _model.HourlyRate,
                _model.DefaultTutorId,
                _model.DefaultSubject,
                _model.DefaultDay,
                _model.DefaultStartTime);

            var result = await Mediator.Send(command);

            if (result.IsSuccess)
            {
                // Handle active status toggle separately
                var student = await StudentRepository.GetByIdAsync(Id);
                if (student is not null && student.IsActive != _model.IsActive)
                {
                    if (_model.IsActive)
                        student.Activate();
                    else
                        student.Deactivate();
                    await StudentRepository.UpdateAsync(student);
                }

                _successMessage = "Student updated successfully.";
                _auditEntries = await AuditEntryRepository.GetByEntityIdAsync(Id);
            }
            else
            {
                _errors = result.Errors.ToList();
            }
        }
        catch (Exception ex)
        {
            _generalError = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }

    private class StudentFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string GuardianName { get; set; } = string.Empty;
        public string GuardianEmail { get; set; } = string.Empty;
        public decimal? HourlyRate { get; set; }
        public bool IsActive { get; set; } = true;
        public Guid? DefaultTutorId { get; set; }
        public string? DefaultSubject { get; set; }
        public DayOfWeek? DefaultDay { get; set; }
        public TimeOnly? DefaultStartTime { get; set; }
    }
}

@page "/reports/balances"
@rendermode InteractiveServer
@using MediatR
@using BatbyEducation.Application.DTOs
@using BatbyEducation.Application.Queries
@inject IMediator Mediator

<PageTitle>Outstanding Balances</PageTitle>

<h1>Outstanding Balances</h1>
<p class="text-muted">Per-student outstanding balances and overdue invoices.</p>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="LoadReport" disabled="@IsLoading">
        @if (IsLoading)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
        }
        Refresh
    </button>
</div>

@if (Balances is not null)
{
    <h3>Student Balances</h3>
    @if (Balances.Count == 0)
    {
        <div class="alert alert-info">No outstanding balances found.</div>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-striped table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Student Name</th>
                        <th class="text-end">Outstanding Balance (£)</th>
                        <th class="text-end">Unpaid Invoices</th>
                        <th class="text-end">Credits (£)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var balance in Balances)
                    {
                        <tr>
                            <td>@balance.StudentName</td>
                            <td class="text-end">@balance.TotalOutstanding.ToString("N2")</td>
                            <td class="text-end">@balance.UnpaidInvoiceCount</td>
                            <td class="text-end">@balance.CreditBalance.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (OverdueInvoices is not null)
{
    <h3>Overdue Invoices</h3>
    @if (OverdueInvoices.Count == 0)
    {
        <div class="alert alert-info">No overdue invoices.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Student Name</th>
                        <th>Guardian Name</th>
                        <th>Invoice Number</th>
                        <th class="text-end">Amount Outstanding (£)</th>
                        <th class="text-end">Days Overdue</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in OverdueInvoices)
                    {
                        <tr class="@(invoice.DaysOverdue > 60 ? "table-danger" : invoice.DaysOverdue > 30 ? "table-warning" : "")">
                            <td>@invoice.StudentName</td>
                            <td>@invoice.GuardianName</td>
                            <td>@invoice.InvoiceNumber</td>
                            <td class="text-end">@invoice.AmountOutstanding.ToString("N2")</td>
                            <td class="text-end">@invoice.DaysOverdue</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (ErrorMessage is not null)
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

@code {
    private List<StudentBalanceDto>? Balances { get; set; }
    private List<OverdueInvoiceDto>? OverdueInvoices { get; set; }
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadReport();
    }

    private async Task LoadReport()
    {
        ErrorMessage = null;
        IsLoading = true;
        try
        {
            Balances = await Mediator.Send(new GetOutstandingBalancesQuery());
            OverdueInvoices = await Mediator.Send(new GetOverdueInvoicesQuery());
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading report: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
}

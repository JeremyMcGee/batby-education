@page "/reports/tutor-earnings"
@rendermode InteractiveServer
@using MediatR
@using BatbyEducation.Application.DTOs
@using BatbyEducation.Application.Queries
@inject IMediator Mediator

<PageTitle>Tutor Earnings Report</PageTitle>

<h1>Tutor Earnings Report</h1>
<p class="text-muted">Per-tutor summary of completed session hours and invoiced revenue.</p>

<div class="row mb-3">
    <div class="col-md-3">
        <label for="startDate" class="form-label">Start Date</label>
        <input type="date" id="startDate" class="form-control" @bind="StartDate" />
    </div>
    <div class="col-md-3">
        <label for="endDate" class="form-label">End Date</label>
        <input type="date" id="endDate" class="form-control" @bind="EndDate" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-primary" @onclick="LoadReport" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Generate Report
        </button>
    </div>
</div>

@if (Earnings is not null)
{
    @if (Earnings.Count == 0)
    {
        <div class="alert alert-info mt-3">No tutor earnings found for the selected date range.</div>
    }
    else
    {
        <div class="table-responsive mt-4">
            <table class="table table-striped table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Tutor Name</th>
                        <th class="text-end">Hours</th>
                        <th class="text-end">Amount (£)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Earnings)
                    {
                        <tr>
                            <td>@entry.TutorName</td>
                            <td class="text-end">@entry.TotalHours.ToString("N1")</td>
                            <td class="text-end">@entry.TotalInvoicedAmount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <th>Total</th>
                        <th class="text-end">@Earnings.Sum(e => e.TotalHours).ToString("N1")</th>
                        <th class="text-end">@Earnings.Sum(e => e.TotalInvoicedAmount).ToString("N2")</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
}

@if (ErrorMessage is not null)
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

@code {
    private DateTime StartDate { get; set; } = DateTime.Today.AddMonths(-1);
    private DateTime EndDate { get; set; } = DateTime.Today;
    private List<TutorEarningsDto>? Earnings { get; set; }
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task LoadReport()
    {
        ErrorMessage = null;
        Earnings = null;

        if (StartDate > EndDate)
        {
            ErrorMessage = "Start date must be before or equal to end date.";
            return;
        }

        IsLoading = true;
        try
        {
            var query = new GetTutorEarningsQuery(
                DateOnly.FromDateTime(StartDate),
                DateOnly.FromDateTime(EndDate));
            Earnings = await Mediator.Send(query);
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading report: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
}

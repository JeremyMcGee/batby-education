@page "/invoices/generate"
@using BatbyEducation.Application.Commands.Invoices
@using BatbyEducation.Domain.Entities
@using BatbyEducation.Domain.Interfaces
@using MediatR
@inject IMediator Mediator
@inject IStudentRepository StudentRepository
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Generate Invoice</PageTitle>

<h3>Generate Invoice</h3>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="generateInvoice">
            <div class="mb-3">
                <label for="student" class="form-label">Student</label>
                <select id="student" class="form-select" @bind="_model.StudentId">
                    <option value="">-- Select Student --</option>
                    @foreach (var student in _students)
                    {
                        <option value="@student.Id">@student.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label for="startDate" class="form-label">Billing Period Start</label>
                <InputDate id="startDate" class="form-control" @bind-Value="_model.BillingPeriodStart" />
            </div>

            <div class="mb-3">
                <label for="endDate" class="form-label">Billing Period End</label>
                <InputDate id="endDate" class="form-control" @bind-Value="_model.BillingPeriodEnd" />
            </div>

            <div class="mb-3">
                <label for="lateFee" class="form-label">Late Cancellation Fee (£)</label>
                <InputNumber id="lateFee" class="form-control" @bind-Value="_model.LateCancellationFee" />
            </div>

            <button type="submit" class="btn btn-primary" disabled="@_submitting">
                @if (_submitting)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Generate Invoice
            </button>
            <a href="/invoices" class="btn btn-secondary ms-2">Cancel</a>
        </EditForm>

        @if (_errors.Count > 0)
        {
            <div class="alert alert-danger mt-3">
                <ul class="mb-0">
                    @foreach (var error in _errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        @if (_success)
        {
            <div class="alert alert-success mt-3">
                Invoice generated successfully.
                <a href="/invoices">View all invoices</a>
            </div>
        }
    </div>
</div>

@code {
    private InvoiceGenerateModel _model = new();
    private List<Student> _students = new();
    private List<string> _errors = new();
    private bool _submitting;
    private bool _success;

    protected override async Task OnInitializedAsync()
    {
        var students = await StudentRepository.GetAllAsync();
        _students = students.ToList();
    }

    private async Task HandleSubmit()
    {
        _errors.Clear();
        _success = false;

        if (_model.StudentId == Guid.Empty)
        {
            _errors.Add("Please select a student.");
            return;
        }

        if (_model.BillingPeriodStart >= _model.BillingPeriodEnd)
        {
            _errors.Add("Billing period start must be before end date.");
            return;
        }

        _submitting = true;

        try
        {
            var command = new GenerateInvoiceCommand(
                _model.StudentId,
                DateOnly.FromDateTime(_model.BillingPeriodStart),
                DateOnly.FromDateTime(_model.BillingPeriodEnd),
                _model.LateCancellationFee);

            var result = await Mediator.Send(command);

            if (result.IsSuccess)
            {
                _success = true;
            }
            else
            {
                _errors.AddRange(result.Errors.Select(e => e.Message));
            }
        }
        catch (Exception ex)
        {
            _errors.Add($"An error occurred: {ex.Message}");
        }
        finally
        {
            _submitting = false;
        }
    }

    private class InvoiceGenerateModel
    {
        public Guid StudentId { get; set; }
        public DateTime BillingPeriodStart { get; set; } = DateTime.Today.AddMonths(-1);
        public DateTime BillingPeriodEnd { get; set; } = DateTime.Today;
        public decimal LateCancellationFee { get; set; } = 25.00m;
    }
}

@page "/sessions/{Id:guid}/reschedule"
@using BatbyEducation.Application.Commands.Sessions
@using BatbyEducation.Domain.Entities
@using BatbyEducation.Domain.Enumerations
@using BatbyEducation.Domain.Interfaces
@using MediatR
@inject IMediator Mediator
@inject ISessionRepository SessionRepository
@inject ITutorRepository TutorRepository
@inject IStudentRepository StudentRepository
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Reschedule Session</PageTitle>

<h1>Reschedule Session</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_session is null)
{
    <div class="alert alert-danger">Session not found.</div>
    <a href="/sessions" class="btn btn-secondary">Back to Sessions</a>
}
else if (_session.Status != SessionStatus.Scheduled)
{
    <div class="alert alert-warning">Only sessions with status 'Scheduled' can be rescheduled. This session is currently '@_session.Status'.</div>
    <a href="/sessions" class="btn btn-secondary">Back to Sessions</a>
}
else
{
    <div class="card mb-3">
        <div class="card-header">Original Session Details</div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Tutor</dt>
                <dd class="col-sm-9">@_tutorName</dd>

                <dt class="col-sm-3">Student</dt>
                <dd class="col-sm-9">@_studentName</dd>

                <dt class="col-sm-3">Subject</dt>
                <dd class="col-sm-9">@_session.Subject</dd>

                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@_session.SessionDate.ToString("dddd, dd MMMM yyyy")</dd>

                <dt class="col-sm-3">Time</dt>
                <dd class="col-sm-9">@_session.StartTime.ToString("HH:mm") - @_session.StartTime.AddMinutes(_session.ScheduledDurationMinutes).ToString("HH:mm")</dd>

                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">@_session.ScheduledDurationMinutes minutes</dd>
            </dl>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h4>New Date &amp; Time</h4>

            <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="RescheduleSession">
                <div class="mb-3">
                    <label for="newDate" class="form-label">New Date</label>
                    <InputDate id="newDate" class="form-control" @bind-Value="_model.NewDate" />
                </div>

                <div class="mb-3">
                    <label for="newTime" class="form-label">New Start Time</label>
                    <input id="newTime" type="time" class="form-control" @bind="_model.NewStartTime" />
                </div>

                <div class="mb-3">
                    <label for="newDuration" class="form-label">Duration (minutes)</label>
                    <input id="newDuration" type="number" class="form-control" @bind="_model.NewDurationMinutes" min="15" max="240" />
                    <div class="form-text">Between 15 and 240 minutes</div>
                </div>

                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @if (_submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Reschedule Session
                </button>
                <a href="/sessions" class="btn btn-secondary ms-2">Cancel</a>
            </EditForm>

            @if (_errors.Count > 0)
            {
                <div class="alert alert-danger mt-3">
                    <ul class="mb-0">
                        @foreach (var error in _errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Session? _session;
    private string _tutorName = string.Empty;
    private string _studentName = string.Empty;
    private RescheduleModel _model = new();
    private bool _loading = true;
    private bool _submitting;
    private List<string> _errors = new();

    protected override async Task OnInitializedAsync()
    {
        _session = await SessionRepository.GetByIdAsync(Id);

        if (_session is not null)
        {
            var tutor = await TutorRepository.GetByIdAsync(_session.TutorId);
            _tutorName = tutor?.Name ?? "Unknown";

            var student = await StudentRepository.GetByIdAsync(_session.StudentId);
            _studentName = student?.Name ?? "Unknown";

            // Pre-fill with original details
            _model.NewDate = _session.SessionDate;
            _model.NewStartTime = _session.StartTime;
            _model.NewDurationMinutes = _session.ScheduledDurationMinutes;
        }

        _loading = false;
    }

    private async Task HandleSubmit()
    {
        _errors.Clear();
        _submitting = true;

        try
        {
            var command = new RescheduleSessionCommand(
                Id,
                _model.NewDate,
                _model.NewStartTime,
                _model.NewDurationMinutes);

            var result = await Mediator.Send(command);

            if (result.IsSuccess)
            {
                Navigation.NavigateTo("/sessions");
            }
            else
            {
                _errors.AddRange(result.Errors.Select(e => e.Message));
            }
        }
        finally
        {
            _submitting = false;
        }
    }

    private class RescheduleModel
    {
        public DateOnly NewDate { get; set; }
        public TimeOnly NewStartTime { get; set; }
        public int NewDurationMinutes { get; set; }
    }
}
